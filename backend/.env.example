# ────────────────────────────────────────────────────────
# 觉学 Backend · 本地开发环境变量
# 复制为 .env 后填入真实值。.env 已在 .gitignore 忽略。
# ────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# PostgreSQL (docker-compose 默认端口 5433)
DATABASE_URL="postgresql://juexue:juexue_dev@localhost:5433/juexue?schema=public"

# JWT (开发阶段随便)
JWT_SECRET=replace_me_in_production

# LLM · MiniMax (主通路)
# https://platform.minimaxi.com/
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=abab6.5s-chat

# LLM · Claude (兜底 · 可留空则不启用)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# 额度阈值（供 Gateway 读取默认配置）
LLM_YEARLY_RESERVE_PERCENT=5
LLM_FALLBACK_MONTHLY_BUDGET_USD=200

# Dev-only: 简化身份注入（生产切 JWT）
DEV_FAKE_USER_ID=dev_user_001
